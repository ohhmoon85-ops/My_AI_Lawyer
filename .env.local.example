# =============================================
# 나의 AI 변호사 - 환경 변수 설정
# =============================================
# 이 파일을 복사하여 .env.local 로 저장하고
# 각 키 값을 실제 값으로 교체하세요.
# .env.local 은 절대 GitHub에 업로드하지 마세요!
# =============================================

# Anthropic Claude API 키
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 국가법령정보 공동활용 API 키 (이용자ID)
# https://open.law.go.kr 에서 신청 후 발급
# 승인 전에는 비워두면 mock 데이터로 동작합니다
LAW_API_KEY=your_law_api_key_here

# Telegram Bot 토큰 (선택사항)
# BotFather (@BotFather) 를 통해 발급
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 배포 후 실제 도메인으로 변경 (Telegram Webhook용)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
